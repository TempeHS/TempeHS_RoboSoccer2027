{
  "name": "TempeHS Simple DevContainer",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "customizations": {
    "vscode": {
      "settings": {
        "files.autoSave": "onFocusChange",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "editor.fontSize": 18,
        "terminal.integrated.defaultProfile.linux": "bash",
        "window.restoreWindows": "preserve",
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },
        "python.languageServer": "Pylance",
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.diagnosticSeverityOverrides": {
          "reportMissingModuleSource": "none"
        },
        "python.terminal.activateEnvironment": false,
        "micropico.openOnStart": true,
        "python.analysis.typeshedPaths": ["~/.micropico-stubs/included"],
        "python.analysis.extraPaths": [
          "~/.micropico-stubs/included",
          "./examples/smooth_"
        ],
        "micropico.syncFolder": "project",
        "workbench.colorTheme": "Dark+",
        "workbench.iconTheme": "vscode-icons",
        "github.copilot.enable": {
          "python": false,
          "html": false,
          "css": false,
          "SQL": false
        },
        "chat.agent.enabled": true
      },
      "extensions": [
        "bierner.markdown-mermaid",
        "bierner.markdown-preview-github-styles",
        "esbenp.prettier-vscode",
        "GitHub.codespaces",
        "mathematic.vscode-pdf",
        "McCarter.start-git-bash",
        "mechatroner.rainbow-csv",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-python.pylint",
        "ms-python.python",
        "ms-python.vscode-python-envs",
        "oderwat.indent-rainbow",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-british-english",
        "yusifaliyevpro.vscicons",
        "saeris.markdown-github-alerts",
        "benpaddlejones.pico-bridge"
      ]
    }
  }
}
